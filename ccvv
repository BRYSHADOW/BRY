------------------------------------------------
-- FUNCTION 4 (TP đảo gần nhất)
------------------------------------------------

local islands = {

Vector3.new(196.21,15.09,184.43),
Vector3.new(1516.50,17.62,-500.17),
Vector3.new(1012.33,10.98,1289.31),
Vector3.new(743.41,14.48,-916.51),
Vector3.new(-320.39,10.89,775.44)

}

local function teleportNearestIsland()

local root = char.HumanoidRootPart
local closest
local dist = math.huge

for _,pos in pairs(islands) do

local d = (root.Position - pos).Magnitude

if d < dist then
dist = d
closest = pos
end

end

root.CFrame = CFrame.new(closest)

end

