local function makeLabel(parent,txt,sz,pos,tsz,bold,col,xa)
    local l=Instance.new("TextLabel",parent)
    l.BackgroundTransparency=1; l.Text=txt; l.Size=sz; l.Position=pos; l.TextSize=tsz
    l.Font=bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextColor3=col or Color3.new(1,1,1)
    l.TextXAlignment=xa or Enum.TextXAlignment.Left
    return l
end
local function makeBtn(parent,txt,sz,pos,bg)
