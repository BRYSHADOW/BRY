local function func5_Spam()
    setActive(5); setStatus("⚡ Spam click + phím...",Color3.fromRGB(255,170,0))
    for _=1,4 do
        if not isRunning or isSelling then break end
        clickScreen(475,250)
        pressKey(Enum.KeyCode.Z); pressKey(Enum.KeyCode.X)
        pressKey(Enum.KeyCode.C); pressKey(Enum.KeyCode.V)
        task.wait(0.001)
    end
end

-- ── MAIN LOOP ────────────────────────────────────
--[[
  Logic:
  - Mỗi vòng: quét Full (func 2)
  - Nếu Full → tắt 4,5 → func 3 → tiếp tục
  - Nếu không Full → func 4 → func 5 → lặp
]]
local function mainLoop()
    while isRunning do
        -- Func 2: quét
        setActive(2); setStatus("🔍 Đang quét...",Color3.fromRGB(150,200,255))
        task.wait(0.05)

        if isScreenFull() then
            -- Dừng 4,5, chuyển sang bán
            isSelling=true
            setStatus("🐟 Full! Đến NPC...",Color3.fromRGB(255,220,0))
            local npcPos=findNPCSeller()
            if npcPos then
                teleportTo(npcPos+Vector3.new(0,3,0))
                task.wait(0.4)
            end
            func3_SellUI()   -- Func 3
            task.wait(0.3)
            isSelling=false
        else
            -- Func 4 → Func 5
            func4_TPIsland()
            if isRunning and not isSelling then
                func5_Spam()
            end
        end

        task.wait(0.08)
    end
    clearActive()
    setStatus("⏸ Đã dừng",Color3.fromRGB(130,190,255))
end

