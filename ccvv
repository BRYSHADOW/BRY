-- ── CHỨC NĂNG 4: Ghim đảo — TP về nếu ra khỏi 10 studs ─
local lockedIsland = nil  -- đảo đang ghim
local function func4_TPIsland()
    setActive(4)
    local r=getRoot(); if not r then return end

    -- Lần đầu: chọn đảo gần nhất để ghim
    if not lockedIsland then
        lockedIsland = nearestIsland()
    end
    if not lockedIsland then return end

    local dist=(r.Position - lockedIsland.pos).Magnitude
    if dist > 10 then
        setStatus("🔁 Ra khỏi "..lockedIsland.name.."! TP về...",Color3.fromRGB(255,180,0))
        teleportTo(lockedIsland.pos)
        task.wait(0.3)
    else
        setStatus("📍 Đang ở "..lockedIsland.name,Color3.fromRGB(100,255,150))
    end
end

