------------------------------------------------
-- FUNCTION 1 (Instant Prompt)
------------------------------------------------

local function instantPrompt()

for _,p in pairs(workspace:GetDescendants()) do
if p:IsA("ProximityPrompt") then
p.HoldDuration = 0
p.RequiresLineOfSight = false
end
end

workspace.DescendantAdded:Connect(function(p)
if p:IsA("ProximityPrompt") then
p.HoldDuration = 0
p.RequiresLineOfSight = false
end
end)

end

------------------------------------------------
-- FUNCTION 2 (TP NPC)
------------------------------------------------

local function teleportNPC()

for _,v in pairs(workspace:GetDescendants()) do

if string.find(v.Name,"bluewaterrobux") then

if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") then

char.HumanoidRootPart.CFrame =
v.HumanoidRootPart.CFrame + Vector3.new(0,3,0)

return

end
end
end

end

