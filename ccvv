local function nearestIsland()
    local r = getRoot(); if not r then return nil end
    local best,bd = nil,math.huge
    for _,isle in ipairs(islands) do
        local d=(r.Position-isle.pos).Magnitude
        if d<bd then bd=d; best=isle end
    end
    return best
end

