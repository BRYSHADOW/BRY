local bossPlatform = nil

-- Tạo kính nhỏ dưới chân player để đứng được
local function createGlassPlatform()
    if bossPlatform and bossPlatform.Parent then
        bossPlatform:Destroy(); bossPlatform = nil
    end
    local r = getRoot(); if not r then return end
    local plat = Instance.new("Part")
    plat.Name         = "BossGlassPlatform"
    plat.Size         = Vector3.new(7, 0.4, 7)
    plat.Anchored     = true
    plat.CanCollide   = true
    plat.CastShadow   = false
    plat.Material     = Enum.Material.Glass
    plat.Color        = Color3.fromRGB(100,200,255)
    plat.Transparency = 0.35
    plat.CFrame       = CFrame.new(r.Position - Vector3.new(0, 3.1, 0))
    plat.Parent       = workspace
    bossPlatform = plat
end

-- Cập nhật vị trí kính theo chân player
local function updatePlatformPos()
    local r = getRoot()
    if r and bossPlatform and bossPlatform.Parent then
        bossPlatform.CFrame = CFrame.new(r.Position - Vector3.new(0, 3.1, 0))
    end
end

-- Tên đảo boss (thứ tự ưu tiên: Island 5 → 1)
local bossIslandNames = {"Island 5","Island 4","Island 3","Island 2","Island 1"}

local function getBossSpawnZone()
    local bossZones = workspace:FindFirstChild("BossZones")
    if not bossZones then return nil end
    for _, islandName in ipairs(bossIslandNames) do
        local island = bossZones:FindFirstChild(islandName)
        if island then
            local spawnZone = island:FindFirstChild("BossSpawnZone")
            if spawnZone then return spawnZone end
        end
    end
    return nil
end

local function getZonePosition(zone)
    if zone:IsA("BasePart") then
        return zone.Position
    elseif zone:IsA("Model") then
        return zone:GetPivot().Position
    else
        local bp = zone:FindFirstChildWhichIsA("BasePart")
        return bp and bp.Position or nil
    end
end

local function bossLoop()
    while isBossRunning do
        task.wait(0.01)  -- quét mỗi 0.01s
        local zone = getBossSpawnZone()
        if zone then
            local pos = getZonePosition(zone)
            if pos then
                -- Tắt auto farm thường khi có boss
                if isRunning then
                    isRunning = false
                    ToggleBtn.Text = "▶ AUTO FARM"
                    ToggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,75)
                end
                isSelling = false

                setStatus("👹 BOSS! TP ngay...", Color3.fromRGB(255,50,50))
                teleportTo(pos + Vector3.new(0, 5, 0))
                task.wait(0.15)
                createGlassPlatform()

                -- Ở lại đánh boss: spam Fishing click + ZXCV + cập nhật kính
                while isBossRunning and getBossSpawnZone() do
                    updatePlatformPos()
                    -- Chức năng 5: click Fishing + phím ZXCV
                    clickFishing()
                    pressKey(Enum.KeyCode.Z); pressKey(Enum.KeyCode.X)
                    pressKey(Enum.KeyCode.C); pressKey(Enum.KeyCode.V)
                    pressKey(Enum.KeyCode.X); pressKey(Enum.KeyCode.C)
                    task.wait(0.01)
                end

                -- Boss xong → xóa kính
                if bossPlatform and bossPlatform.Parent then
                    bossPlatform:Destroy(); bossPlatform = nil
                end
                setStatus("✅ Boss xong! Tiếp tục...", Color3.fromRGB(100,255,150))
            end
        end
    end

    -- Cleanup khi tắt Boss Farm
    if bossPlatform and bossPlatform.Parent then
        bossPlatform:Destroy(); bossPlatform = nil
    end
    clearActive()
    setStatus("⏸ Boss Farm dừng", Color3.fromRGB(130,190,255))
end

-- ═══════════════════════════════════════════════════
--              MAIN AUTO FARM LOOP
-- ═══════════════════════════════════════════════════
local function mainLoop()
    while isRunning do
        setActive(2); setStatus("🔍 Đang quét...", Color3.fromRGB(150,200,255))
        task.wait(0.05)

        if isScreenFull() then
            isSelling = true
            setStatus("🐟 Full! Đến NPC...", Color3.fromRGB(255,220,0))
            local npcPos = findNPCSeller()
            if npcPos then
                teleportTo(npcPos + Vector3.new(0,3,0))
                task.wait(0.4)
            end
            func3_SellUI()
            task.wait(0.3)
            isSelling = false
        else
            func4_TPIsland()
            if isRunning and not isSelling then
                func5_Spam()
            end
        end

        task.wait(0.08)
    end
    clearActive()
    setStatus("⏸ Đã dừng", Color3.fromRGB(130,190,255))
end

