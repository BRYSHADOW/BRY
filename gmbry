local function rainbow(obj, speed)
    local hue = 0
    RunService.Heartbeat:Connect(function(dt)
        if not obj or not obj.Parent then return end
        hue = (hue + dt * speed) % 1
        obj.Color = Color3.fromHSV(hue, 1, 1)
    end)
end
